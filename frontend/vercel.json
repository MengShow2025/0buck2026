{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Vercel-Config-Check", "value": "true" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://zerobuck-api.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
